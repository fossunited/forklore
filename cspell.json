{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "language": "en-US,hi-IN",
  "version": "0.2",
  "caseSensitive": false,
  "dictionaryDefinitions": [
    {
      "name": "accepted-words",
      "path": ".cspell/accepted-words.txt",
      "addWords": true
    }
  ],
  "dictionaries": ["accepted-words"],
  "ignorePaths": [
    "node_modules",
    ".cspell/project-words.txt",
    "dist",
    ".nuxt",
    ".output",
    ".data",
    "**/*.svg",
    "package.json",
    "content/sample.json",
    "**/*.ts"
  ]
}
